rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users: can only read/write their own profile ─────────────────
    // Subscription fields are managed exclusively by Cloud Functions.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && !('subscription_tier' in request.resource.data
             && request.resource.data.subscription_tier != 'launch')
        && !('subscription_status' in request.resource.data)
        && !('subscription_expires_at' in request.resource.data)
        && !('subscription_plan' in request.resource.data)
        && !('last_payment_at' in request.resource.data)
        && !('last_paymob_order_id' in request.resource.data)
        && !('last_paymob_transaction_id' in request.resource.data)
        && !('paymob_card_token' in request.resource.data)
        && !('paymob_card_last4' in request.resource.data)
        && !('paymob_card_brand' in request.resource.data)
        && !('paymob_auto_renew' in request.resource.data)
        && !('paymob_renewal_attempts' in request.resource.data)
        && !('payment_source' in request.resource.data)
        && !('paymob_subscription_id' in request.resource.data)
        && !('paymob_subscription_state' in request.resource.data)
        && !('paymob_card_token_internal' in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == userId
        // Prevent client from modifying billing-managed fields
        && (!('subscription_tier' in request.resource.data)
            || request.resource.data.subscription_tier
               == resource.data.subscription_tier)
        && (!('subscription_status' in request.resource.data)
            || request.resource.data.subscription_status
               == resource.data.subscription_status)
        && (!('subscription_expires_at' in request.resource.data)
            || request.resource.data.subscription_expires_at
               == resource.data.subscription_expires_at)
        && (!('subscription_plan' in request.resource.data)
            || request.resource.data.subscription_plan
               == resource.data.subscription_plan)
        && (!('last_payment_at' in request.resource.data)
            || request.resource.data.last_payment_at
               == resource.data.last_payment_at)
        && (!('last_paymob_order_id' in request.resource.data)
            || request.resource.data.last_paymob_order_id
               == resource.data.last_paymob_order_id)
        && (!('last_paymob_transaction_id' in request.resource.data)
            || request.resource.data.last_paymob_transaction_id
               == resource.data.last_paymob_transaction_id)
        && (!('last_iap_platform' in request.resource.data)
            || request.resource.data.last_iap_platform
               == resource.data.last_iap_platform)
        && (!('last_iap_transaction_id' in request.resource.data)
            || request.resource.data.last_iap_transaction_id
               == resource.data.last_iap_transaction_id)
        // Card token & payment_source: server-only
        && (!('paymob_card_token' in request.resource.data)
            || request.resource.data.paymob_card_token
               == resource.data.paymob_card_token)
        && (!('paymob_card_last4' in request.resource.data)
            || request.resource.data.paymob_card_last4
               == resource.data.paymob_card_last4)
        && (!('paymob_card_brand' in request.resource.data)
            || request.resource.data.paymob_card_brand
               == resource.data.paymob_card_brand)
        && (!('paymob_renewal_attempts' in request.resource.data)
            || request.resource.data.paymob_renewal_attempts
               == resource.data.paymob_renewal_attempts)
        && (!('payment_source' in request.resource.data)
            || request.resource.data.payment_source
               == resource.data.payment_source)
        // Subscription module fields: server-only
        && (!('paymob_subscription_id' in request.resource.data)
            || request.resource.data.paymob_subscription_id
               == resource.data.paymob_subscription_id)
        && (!('paymob_subscription_state' in request.resource.data)
            || request.resource.data.paymob_subscription_state
               == resource.data.paymob_subscription_state)
        && (!('paymob_card_token_internal' in request.resource.data)
            || request.resource.data.paymob_card_token_internal
               == resource.data.paymob_card_token_internal)
        // paymob_auto_renew: client may toggle (bool only)
        && (!('paymob_auto_renew' in request.resource.data)
            || request.resource.data.paymob_auto_renew is bool);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Payment Logs: read-only for the user, write by CF only ──────
    match /payment_logs/{docId} {
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      // No client-side write — only Cloud Functions (Admin SDK) write here
    }

    // ─── Helper: owner check for data collections ─────────────────────
    // All data docs have a 'user_id' field that must match the caller's UID.
    // On update, user_id must not change (immutable).

    // ─── Helper: validate required transaction fields ───────────────
    function validTransactionFields() {
      let d = request.resource.data;
      return d.title is string && d.title.size() > 0 && d.title.size() <= 200
        && d.amount is number
        && d.date_time is timestamp
        && d.category_id is string && d.category_id.size() <= 128
        && d.payment_method is string && d.payment_method.size() <= 50
        && d.user_id is string && d.user_id.size() <= 128;
    }

    // ─── Helper: validate required supplier fields ───────────────────
    function validSupplierFields() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 200
        && d.category is string && d.category.size() <= 100
        && d.balance is number
        && d.user_id is string && d.user_id.size() <= 128;
    }

    // ─── Helper: validate required purchase fields ──────────────────
    function validPurchaseFields() {
      let d = request.resource.data;
      return d.supplier_id is string && d.supplier_id.size() > 0 && d.supplier_id.size() <= 128
        && d.supplier_name is string && d.supplier_name.size() <= 200
        && d.date is string && d.date.size() <= 50
        && d.payment_status is int && d.payment_status >= 0 && d.payment_status <= 2
        && d.amount_paid is number && d.amount_paid >= 0
        && d.user_id is string && d.user_id.size() <= 128;
    }

    // ─── Helper: validate required payment fields ───────────────────
    function validPaymentFields() {
      let d = request.resource.data;
      return d.supplier_id is string && d.supplier_id.size() > 0 && d.supplier_id.size() <= 128
        && d.supplier_name is string && d.supplier_name.size() <= 200
        && d.amount is number && d.amount > 0
        && d.date is string && d.date.size() <= 50
        && d.method is string && d.method.size() <= 50
        && d.user_id is string && d.user_id.size() <= 128;
    }

    // ─── Helper: validate required product fields ───────────────────
    function validProductFields() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 200
        && d.variants is list && d.variants.size() <= 100
        && d.user_id is string && d.user_id.size() <= 128;
    }

    // ─── Helper: validate required sale fields ──────────────────────
    function validSaleFields() {
      let d = request.resource.data;
      return d.items is list && d.items.size() <= 200
        && d.payment_method is string && d.payment_method.size() <= 50
        && d.payment_status is int && d.payment_status >= 0 && d.payment_status <= 3
        && d.order_status is int && d.order_status >= 0 && d.order_status <= 4
        && d.user_id is string && d.user_id.size() <= 128;
    }

    // ─── Helper: validate required goods receipt fields ─────────────
    function validGoodsReceiptFields() {
      let d = request.resource.data;
      return d.supplier_id is string && d.supplier_id.size() > 0 && d.supplier_id.size() <= 128
        && d.date is string && d.date.size() <= 50
        && d.items is list && d.items.size() <= 200
        && d.status is int && d.status >= 0 && d.status <= 2
        && d.user_id is string && d.user_id.size() <= 128;
    }

    // ─── Helper: validate required conversion order fields ──────────
    function validConversionOrderFields() {
      let d = request.resource.data;
      return d.product_id is string && d.product_id.size() > 0 && d.product_id.size() <= 128
        && d.source_variant_id is string && d.source_variant_id.size() <= 128
        && d.source_quantity is number && d.source_quantity > 0
        && d.outputs is list && d.outputs.size() <= 100
        && d.user_id is string && d.user_id.size() <= 128;
    }

    // Transactions
    match /transactions/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && validTransactionFields();
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && validTransactionFields();
    }

    // Categories
    match /categories/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
    }

    // Products
    match /products/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && validProductFields();
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && validProductFields();
    }

    // Suppliers
    match /suppliers/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && validSupplierFields();
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && validSupplierFields();
    }

    // Purchases
    match /purchases/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && validPurchaseFields();
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && validPurchaseFields();
    }

    // Payments
    match /payments/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && validPaymentFields();
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && validPaymentFields();
    }

    // Recurring Transactions
    match /recurring_transactions/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
    }

    // Goods Receipts
    match /goods_receipts/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && validGoodsReceiptFields();
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && validGoodsReceiptFields();
    }

    // Sales
    match /sales/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && validSaleFields();
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && validSaleFields();
    }

    // Balance Sheet (user-scoped document)
    match /balance_sheet/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ─── Shopify Integration Collections ──────────────────────

    // Shopify Connections (OAuth tokens, sync settings)
    // access_token and webhook_ids are managed exclusively by Cloud Functions.
    // Client may read/update sync settings but MUST NOT modify token fields.
    match /shopify_connections/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        // Prevent client from modifying CF-managed secrets
        && (!('access_token' in request.resource.data)
            || request.resource.data.access_token
               == resource.data.access_token)
        && (!('webhook_ids' in request.resource.data)
            || request.resource.data.webhook_ids
               == resource.data.webhook_ids)
        // Prevent SSRF via shop_domain tampering + status spoofing
        && (!('shop_domain' in request.resource.data)
            || request.resource.data.shop_domain
               == resource.data.shop_domain)
        && (!('status' in request.resource.data)
            || request.resource.data.status
               == resource.data.status);
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        // Client-created docs must NOT include an access_token
        && !('access_token' in request.resource.data);
    }

    // Shopify Product Mappings (Revvo ↔ Shopify variant links)
    match /shopify_product_mappings/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
    }

    // Shopify Sync Log (audit trail for debugging)
    match /shopify_sync_log/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      // App can create log entries; Cloud Functions also write via Admin SDK
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid;
    }

    // Shopify Webhook Queue (Cloud Functions write, app reads)
    // Writes come from Admin SDK (bypasses rules), so only read rules needed.
    match /shopify_webhook_queue/{docId} {
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      // No client-side write — only Cloud Functions (Admin SDK) write here
    }

    // Conversion Orders (breakdown audit trail)
    match /conversion_orders/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && validConversionOrderFields();
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && validConversionOrderFields();
    }

    // Bosta Connections (API key managed by CF, client reads + updates sync settings)
    match /bosta_connections/{docId} {
      allow read: if request.auth != null
        && request.auth.uid == docId;
      allow update: if request.auth != null
        && request.auth.uid == docId
        // Client may only toggle auto_sync_enabled
        && (!('api_key_encrypted' in request.resource.data)
            || request.resource.data.api_key_encrypted
               == resource.data.api_key_encrypted)
        && (!('status' in request.resource.data)
            || request.resource.data.status
               == resource.data.status);
      // create & delete handled by Cloud Functions (Admin SDK)
    }

    // Bosta Shipments (Cloud Functions write, client reads)
    match /bosta_shipments/{docId} {
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      // No client-side write — only Cloud Functions (Admin SDK) write here
    }

    // Deny everything else by default (Firestore's implicit behavior)
  }
}